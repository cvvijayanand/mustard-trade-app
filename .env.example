# Shopify (from Dev Dashboard → Settings, or `shopify app env show`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_products,write_metaobjects,write_metaobject_definitions,read_customers,write_customers,write_draft_orders,write_app_proxy

# App URL — Vercel production URL or custom domain (no trailing slash)
SHOPIFY_APP_URL=https://trade-app.mustardliving.com

# Optional — set if the store uses a custom domain (e.g. www.mustardliving.com)
# SHOP_CUSTOM_DOMAIN=www.mustardliving.com

# PostgreSQL — required for Vercel (use Neon, Vercel Postgres, or Supabase)
# Local dev: same variable; use a dev database URL
mustard_trade_DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

NODE_ENV=production
